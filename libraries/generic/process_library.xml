    <port id="OUT" x="2.5" y="1.25" dx="1" dy="0" />
  </symbol>

  <assembly id="PUMP_SKID" name="Pump Skid" width="18" height="8">
    <port id="IN" x="0" y="4" dx="-1" dy="0" />
    <port id="OUT" x="18" y="4" dx="1" dy="0" />
